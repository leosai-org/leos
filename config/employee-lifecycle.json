  "assignable_states": ["active"],
  "schedule_timezone": "UTC",
  "resource_profile_sync_required_for_activation": true,
  "history_persistence_required": true,
  "production_state_write_allowed_during_acceptance": false,
  "docker_socket_mount_allowed": false,
  "production_network_attachment_allowed": false
}
