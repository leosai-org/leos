{
  "contract_version": "leos.employee-lifecycle-policy.v1",
  "definition_contract": "leos.employee-definition.v2",
  "lifecycle_contract": "leos.employee-lifecycle.v1",
  "eligibility_contract": "leos.employee-execution-eligibility.v1",
  "authority_service": "employee-registry",
  "mandatory_before_resource_admission": true,
  "mandatory_before_running": true,
  "fail_closed": true,
  "soft_delete": "archive",
  "states": ["draft", "validated", "active", "paused", "disabled", "archived"],
