{
  "$id": "https://leosai.org/contracts/security-baseline-report.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "checks": {
      "items": {
        "type": "object"
      },
      "minItems": 5,
      "type": "array"
    },
    "component_reports": {
      "type": "object"
    },
    "contract_version": {
      "const": "leos.security-baseline-report.v1"
    },
    "counts": {
      "type": "object"
    },
    "generated_at": {
      "minLength": 1,
      "type": "string"
    },
    "repair_requires_confirmation": {
      "const": true
    },
    "report_id": {
      "pattern": "^security-[a-f0-9]{16}$",
      "type": "string"
    },
    "safety": {
      "additionalProperties": false,
      "properties": {
        "container_daemon_contacted": {
          "const": false
        },
        "external_network_contacted": {
          "const": false
        },
        "plaintext_secret_exposed": {
          "const": false
        },
        "production_network_attached": {
          "const": false
        },
        "production_state_accessed": {
          "const": false
        },
        "read_only": {
          "type": "boolean"
        },
        "secret_material_copied": {
          "const": false
        }
      },
      "required": [
        "read_only",
        "external_network_contacted",
        "container_daemon_contacted",
        "plaintext_secret_exposed",
        "secret_material_copied",
        "production_state_accessed",
        "production_network_attached"
      ],
      "type": "object"
    },
    "source_release": {
      "const": "0.1.0-dev-preview-rc9"
    },
    "source_tree_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "status": {
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "target_root": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "contract_version",
    "report_id",
    "status",
    "target_root",
    "source_release",
    "source_tree_sha256",
    "checks",
    "counts",
    "component_reports",
    "repair_requires_confirmation",
    "generated_at",
    "safety"
  ],
  "title": "LEOS Security Baseline Report",
  "type": "object"
}
