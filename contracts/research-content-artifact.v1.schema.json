{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leosai.org/contracts/research-content-artifact.v1.schema.json",
  "title": "LEOS Research and Content Artifact",
  "type": "object",
  "required": [
    "contract_version",
    "artifact_id",
    "run_id",
    "goal_id",
    "employee_id",
    "title",
    "status",
    "version",
    "content",
    "content_sha256",
    "source_ids",
    "sources",
    "review",
    "execution"
  ],
  "properties": {
    "contract_version": {"const": "leos.research-content-artifact.v1"},
    "artifact_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "goal_id": {"type": "string", "minLength": 1},
    "employee_id": {"const": "research-content-employee"},
    "title": {"type": "string", "minLength": 1},
    "status": {"enum": ["revision_required", "reviewed", "approved"]},
    "version": {"type": "integer", "minimum": 1},
    "content": {"type": "string", "minLength": 1},
    "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "sources": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "review": {"type": "object"},
    "execution": {
      "type": "object",
      "required": [
        "employee_id",
        "goal_id",
        "run_id",
        "job_id",
        "assignment_id",
        "execution_id",
        "decision_id",
        "reservation_id",
        "priority"
      ]
    }
  },
  "additionalProperties": true
}
