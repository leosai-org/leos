{
  "$id": "https://leosai.org/contracts/service-inventory.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "leos.service-inventory.v1"
    },
    "daemon_contact_authorized": {
      "type": "boolean"
    },
    "daemon_contacted": {
      "const": false
    },
    "generated_at": {
      "minLength": 1,
      "type": "string"
    },
    "services": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "source": {
      "enum": [
        "fixture",
        "catalog",
        "daemon"
      ]
    },
    "summary": {
      "type": "object"
    }
  },
  "required": [
    "contract_version",
    "services",
    "summary",
    "source",
    "generated_at",
    "daemon_contact_authorized",
    "daemon_contacted"
  ],
  "title": "LEOS Service Inventory",
  "type": "object"
}
