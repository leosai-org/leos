{
  "$id": "https://leosai.org/contracts/cli-result.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "command": {
      "minLength": 1,
      "type": "string"
    },
    "contract_version": {
      "const": "leos.cli-result.v1"
    },
    "exit_code": {
      "minimum": 0,
      "type": "integer"
    },
    "generated_at": {
      "minLength": 1,
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "payload": {
      "type": "object"
    },
    "payload_contract": {
      "minLength": 1,
      "type": "string"
    },
    "safety": {
      "additionalProperties": false,
      "properties": {
        "container_daemon_contacted": {
          "const": false
        },
        "external_network_contacted": {
          "const": false
        },
        "plaintext_secret_exposed": {
          "const": false
        },
        "production_network_attached": {
          "const": false
        },
        "production_state_accessed": {
          "const": false
        },
        "read_only": {
          "type": "boolean"
        }
      },
      "required": [
        "read_only",
        "external_network_contacted",
        "container_daemon_contacted",
        "plaintext_secret_exposed",
        "production_state_accessed",
        "production_network_attached"
      ],
      "type": "object"
    }
  },
  "required": [
    "contract_version",
    "command",
    "ok",
    "exit_code",
    "generated_at",
    "payload_contract",
    "payload",
    "safety"
  ],
  "title": "LEOS CLI Result",
  "type": "object"
}
