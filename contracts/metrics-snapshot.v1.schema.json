{
  "$id": "https://leosai.org/contracts/metrics-snapshot.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "const": "leos.metrics-snapshot.v1"
    },
    "generated_at": {
      "minLength": 1,
      "type": "string"
    },
    "metrics": {
      "type": "object"
    },
    "safety": {
      "additionalProperties": false,
      "properties": {
        "container_daemon_contacted": {
          "const": false
        },
        "external_network_contacted": {
          "const": false
        },
        "plaintext_secret_exposed": {
          "const": false
        },
        "production_network_attached": {
          "const": false
        },
        "production_state_accessed": {
          "const": false
        },
        "read_only": {
          "type": "boolean"
        },
        "secret_material_copied": {
          "const": false
        }
      },
      "required": [
        "read_only",
        "external_network_contacted",
        "container_daemon_contacted",
        "plaintext_secret_exposed",
        "secret_material_copied",
        "production_state_accessed",
        "production_network_attached"
      ],
      "type": "object"
    },
    "snapshot_id": {
      "pattern": "^metrics-[a-f0-9]{16}$",
      "type": "string"
    },
    "source": {
      "enum": [
        "fixture",
        "local-read-only"
      ]
    },
    "target_root": {
      "minLength": 1,
      "type": "string"
    }
  },
  "required": [
    "contract_version",
    "snapshot_id",
    "target_root",
    "metrics",
    "source",
    "generated_at",
    "safety"
  ],
  "title": "LEOS Metrics Snapshot",
  "type": "object"
}
