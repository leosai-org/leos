{
  "$id": "https://leosai.org/contracts/health-aggregate.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "aggregate_id": {
      "pattern": "^health-[a-f0-9]{16}$",
      "type": "string"
    },
    "container_daemon_contacted": {
      "const": false
    },
    "contract_version": {
      "const": "leos.health-aggregate.v1"
    },
    "external_network_contacted": {
      "const": false
    },
    "generated_at": {
      "minLength": 1,
      "type": "string"
    },
    "safety": {
      "additionalProperties": false,
      "properties": {
        "container_daemon_contacted": {
          "const": false
        },
        "external_network_contacted": {
          "const": false
        },
        "plaintext_secret_exposed": {
          "const": false
        },
        "production_network_attached": {
          "const": false
        },
        "production_state_accessed": {
          "const": false
        },
        "read_only": {
          "type": "boolean"
        },
        "secret_material_copied": {
          "const": false
        }
      },
      "required": [
        "read_only",
        "external_network_contacted",
        "container_daemon_contacted",
        "plaintext_secret_exposed",
        "secret_material_copied",
        "production_state_accessed",
        "production_network_attached"
      ],
      "type": "object"
    },
    "services": {
      "items": {
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "status": {
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "summary": {
      "type": "object"
    }
  },
  "required": [
    "contract_version",
    "aggregate_id",
    "status",
    "services",
    "summary",
    "external_network_contacted",
    "container_daemon_contacted",
    "generated_at",
    "safety"
  ],
  "title": "LEOS Health Aggregate",
  "type": "object"
}
