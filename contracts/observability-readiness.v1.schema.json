{
  "$id": "https://leosai.org/contracts/observability-readiness.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "blockers": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "checks": {
      "items": {
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "contract_version": {
      "const": "leos.observability-readiness.v1"
    },
    "generated_at": {
      "minLength": 1,
      "type": "string"
    },
    "readiness_id": {
      "pattern": "^observability-[a-f0-9]{16}$",
      "type": "string"
    },
    "safety": {
      "additionalProperties": false,
      "properties": {
        "container_daemon_contacted": {
          "const": false
        },
        "external_network_contacted": {
          "const": false
        },
        "plaintext_secret_exposed": {
          "const": false
        },
        "production_network_attached": {
          "const": false
        },
        "production_state_accessed": {
          "const": false
        },
        "read_only": {
          "type": "boolean"
        },
        "secret_material_copied": {
          "const": false
        }
      },
      "required": [
        "read_only",
        "external_network_contacted",
        "container_daemon_contacted",
        "plaintext_secret_exposed",
        "secret_material_copied",
        "production_state_accessed",
        "production_network_attached"
      ],
      "type": "object"
    },
    "status": {
      "enum": [
        "ready",
        "blocked"
      ]
    }
  },
  "required": [
    "contract_version",
    "readiness_id",
    "status",
    "checks",
    "blockers",
    "generated_at",
    "safety"
  ],
  "title": "LEOS Observability Readiness",
  "type": "object"
}
