{
  "$id": "https://leosai.org/contracts/diagnostics-bundle-manifest.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "archive_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "archive_sha256": {
      "pattern": "^[a-f0-9]{64}$",
      "type": [
        "string",
        "null"
      ]
    },
    "archive_size_bytes": {
      "minimum": 0,
      "type": "integer"
    },
    "bundle_id": {
      "pattern": "^diagnostics-[a-f0-9]{16}$",
      "type": "string"
    },
    "confirmation_token": {
      "pattern": "^diagnostics-confirm-[a-f0-9]{16}$",
      "type": "string"
    },
    "contract_version": {
      "const": "leos.diagnostics-bundle-manifest.v1"
    },
    "entries": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "execution_authorized": {
      "type": "boolean"
    },
    "generated_at": {
      "minLength": 1,
      "type": "string"
    },
    "limits": {
      "type": "object"
    },
    "plaintext_secret_exposed": {
      "const": false
    },
    "redaction_count": {
      "minimum": 0,
      "type": "integer"
    },
    "redaction_required": {
      "const": true
    },
    "requires_confirmation": {
      "const": true
    },
    "safety": {
      "additionalProperties": false,
      "properties": {
        "container_daemon_contacted": {
          "const": false
        },
        "external_network_contacted": {
          "const": false
        },
        "plaintext_secret_exposed": {
          "const": false
        },
        "production_network_attached": {
          "const": false
        },
        "production_state_accessed": {
          "const": false
        },
        "read_only": {
          "type": "boolean"
        },
        "secret_material_copied": {
          "const": false
        }
      },
      "required": [
        "read_only",
        "external_network_contacted",
        "container_daemon_contacted",
        "plaintext_secret_exposed",
        "secret_material_copied",
        "production_state_accessed",
        "production_network_attached"
      ],
      "type": "object"
    },
    "secret_material_copied": {
      "const": false
    },
    "skipped": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "status": {
      "enum": [
        "planned",
        "exported"
      ]
    },
    "target_root": {
      "minLength": 1,
      "type": "string"
    },
    "total_bytes": {
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "contract_version",
    "bundle_id",
    "target_root",
    "status",
    "entries",
    "skipped",
    "limits",
    "requires_confirmation",
    "confirmation_token",
    "execution_authorized",
    "redaction_required",
    "plaintext_secret_exposed",
    "secret_material_copied",
    "generated_at",
    "safety"
  ],
  "title": "LEOS Diagnostics Bundle Manifest",
  "type": "object"
}
